digraph EnterpriseComplianceNeuralNet {
    rankdir=LR;
    splines=polyline;
    nodesep=0.3;
    ranksep=1.5;

    node [fontname="monospace", fontsize=10, shape=box, style="filled",
          fillcolor="#ffffff", color="#000000"];
    edge [fontname="monospace", fontsize=8, color="#000000"];

    // LAYER 0: INPUT
    subgraph cluster_input {
        label = "INPUT LAYER: Context & Triggers";
        In_Loc_ON        [label="Loc: Ontario", shape=circle];
        In_Loc_QC        [label="Loc: Quebec", shape=circle];
        In_Loc_Fed       [label="Loc: CA Fed", shape=circle];
        In_Loc_US_CA     [label="Loc: California", shape=circle];
        In_Loc_US_TX     [label="Loc: Texas", shape=circle];
        In_Loc_US_NY     [label="Loc: New York", shape=circle];
        In_Loc_EU        [label="Loc: European Union", shape=circle];
        In_Loc_UK        [label="Loc: United Kingdom", shape=circle];
        In_Loc_AU        [label="Loc: Australia", shape=circle];
        In_Loc_SG        [label="Loc: Singapore", shape=circle];

        In_Data_PHI      [label="Data: PHI / Health", shape=circle];
        In_Data_Bio      [label="Data: Biometric", shape=circle];
        In_Data_PII      [label="Data: PII (name, ID, etc.)", shape=circle];
        In_Data_PCI      [label="Data: PCI / Cardholder", shape=circle];
        In_Data_Fin      [label="Data: Financial", shape=circle];
        In_Data_IoT      [label="Data: IoT Sensor", shape=circle];

        In_Act_XBorder   [label="Act: Cross-Border Transfer", shape=circle];
        In_Act_AI        [label="Act: AI Profiling / ADMT", shape=circle];
        In_Act_Mktg      [label="Act: Direct Marketing", shape=circle];
        In_Act_IoT       [label="Act: IoT Data Collection", shape=circle];
        In_Act_ThirdParty[label="Act: Vendor / Third-Party Sharing", shape=circle];

        In_Evt_Breach    [label="Event: Security Incident", shape=doublecircle];
        In_Evt_DSAR      [label="Event: Consumer Request", shape=doublecircle];
        In_Evt_RegAudit  [label="Event: Regulatory Audit / Inquiry", shape=doublecircle];
        In_Evt_PolicyChg [label="Event: Internal Policy Change", shape=doublecircle];
    }

    // LAYER 1: STATUTORY FRAMEWORKS
    subgraph cluster_hidden1 {
        label = "HIDDEN LAYER 1: Statutory Frameworks";
        H1_PHIPA   [label="Framework:\nPHIPA (ON)"];
        H1_Law25   [label="Framework:\nLaw 25 (QC)"];
        H1_PIPEDA  [label="Framework:\nPIPEDA (CA)"];
        H1_CPRA    [label="Framework:\nCCPA / CPRA (US)"];
        H1_GDPR    [label="Framework:\nGDPR (EU)"];
        H1_UK_GDPR [label="Framework:\nUK-GDPR"];
        H1_APP     [label="Framework:\nAPP (AU)"];
        H1_PDPA    [label="Framework:\nPDPA (SG)"];
        H1_HIPAA   [label="Framework:\nHIPAA (US Health)"];
        H1_SOX     [label="Framework:\nSOX (Financial Reporting)"];
        H1_PCI_DSS [label="Framework:\nPCI-DSS (Card Data)"];
        H1_NIST    [label="Framework:\nNIST CSF (Cybersecurity)"];
        H1_FIPPA   [label="Framework:\nFIPPA (ON)"];
        H1_PIPA_AB [label="Framework:\nPIPA (AB)"];
        H1_BIPA    [label="Framework:\nBIPA (IL)"];
        H1_NYDFS   [label="Framework:\nNYDFS Part 500 (NY)"];
        H1_NYC_AIBias[label="Framework:\nNYC Local Law 144 (AI Bias Audits)"];
        H1_MHMDA   [label="Framework:\nMy Health My Data Act (WA)"];
        H1_FERPA   [label="Framework:\nFERPA (US Federal)"];
        H1_FTCAct5 [label="Framework:\nFTC Act Section 5 (US Federal)"];
        H1_EU_AIAct[label="Framework:\nEU AI Act"];
        H1_ISO27001[label="Framework:\nISO/IEC 27001 (Global)"];
    }

    // LAYER 1.5: PRIVACY TORTS
    subgraph cluster_torts {
        label = "HIDDEN LAYER 1.5: Privacy Torts";
        T_US_Intrusion   [label="US Tort:\nIntrusion upon seclusion"];
        T_US_PubDisc     [label="US Tort:\nPublic disclosure\nof private facts"];
        T_US_FalseLight  [label="US Tort:\nFalse light"];
        T_US_Approp      [label="US Tort:\nAppropriation\nof name/likeness"];
        T_CA_Intrusion   [label="Canada Tort:\nIntrusion upon seclusion"];
        T_CA_PubDisc     [label="Canada Tort:\nPublic disclosure\nof private facts"];
        T_CA_FalseLight  [label="Canada Tort:\nFalse light"];
        T_CA_Approp      [label="Canada Tort:\nAppropriation"];
        T_EU_Infringement[label="EU Tort:\nInfringement of personality\nrights (GDPR Art.8)"];
        T_EU_BreachConf  [label="EU Tort:\nBreach of confidentiality"];
        T_EU_DataProtViol[label="EU Tort:\nData protection violation"];
        T_EU_RTBF        [label="EU Tort:\nRight to be forgotten"];
    }

    // LAYER 2: CROSS-CUTTING GOVERNANCE
    subgraph cluster_hidden2 {
        label = "HIDDEN LAYER 2: Cross-Cutting Governance";
        H2_Gov_Policy   [label="Control:\nEnterprise Privacy Policy"];
        H2_Gov_Training [label="Control:\nPrivacy & Security Training"];
        H2_Gov_Vendor   [label="Control:\nVendor-Third-Party Management"];
        H2_Gov_Monitoring[label="Control:\nContinuous Monitoring & Logging"];
        H2_Gov_Incident [label="Control:\nIncident Response Plan"];
        H2_Gov_Access   [label="Control:\nAccess Control & Least Privilege"];
        H2_Gov_Encrypt  [label="Control:\nEncryption (Data-at-Rest & In-Transit)"];
        H2_Gov_RetPol   [label="Control:\nData Retention & Disposal Policy"];
    }

    // LAYER 2.5: CERTIFICATIONS
    subgraph cluster_cert {
        label = "HIDDEN LAYER 2.5: Certification Requirements";
        Cert_SOC1   [label="Certification:\nSOC 1 (SSAE 18)"];
        Cert_SOC2   [label="Certification:\nSOC 2 (Trust Services Criteria)"];
        Cert_CHI    [label="Certification:\nCanada Health Infoway (CHI)"];
        Cert_HIPAA  [label="Certification:\nHIPAA Compliance"];
        Cert_EU_EQ  [label="Certification:\nEU-Equivalent\n(ISO 27001 / EU Cloud Code)"];
    }

    // LAYER 3: OPERATIONAL CONTROLS
    subgraph cluster_hidden3 {
        label = "HIDDEN LAYER 3: Required Operational Controls";
        H3_Assessments   [label="Control:\nImpact Assessments"];
        H3_Gov_RoPA      [label="Control:\nData Mapping & Inventory (RoPA)"];
        H3_Rights_Mgmt   [label="Control:\nData Subject Rights (DSAR)"];
        H3_Breach_Resp   [label="Control:\nBreach Triage & SLA"];
        H3_Retention     [label="Control:\nData Lifecycle / Destruction"];
        H3_AI_Gov        [label="Control:\nAlgorithmic Transparency"];
        H3_Leadership    [label="Control:\nDesignated Privacy Officer"];
        H3_Training      [label="Control:\nRole-Based Privacy Training"];
        H3_VendorMgmt    [label="Control:\nVendor Due-Diligence & Contracts"];
        H3_Encrypt       [label="Control:\nEncryption & Key Management"];
        H3_AccessCtrl    [label="Control:\nRBAC / MFA & Least Privilege"];
        H3_Monitoring    [label="Control:\nSIEM / Audit-Log Monitoring"];
        H3_IncidentPlan  [label="Control:\nFormal Incident Response Playbook"];
        H3_RetentionLog  [label="Control:\nRetention Schedule & Disposal Proof"];
        H3_TRA_PHIPA [label="Control:\nThreat and Risk Assessment (TRA)\nCustodians must conduct a TRA prior to introducing new EHR systems or major architectural changes."];
        H3_AgentAgreement_PHIPA [label="Control:\nAgent Agreements\nWritten agreements with third-party agents restricting PHI use to authorized purposes."];
        H3_FOI_Compliance_FIPPA [label="Control:\nFreedom of Information Compliance\nPublic institutions must respond to formal access to information requests within 30 days, applying specific statutory exemptions where necessary."];
        H3_TIA_Law25 [label="Control:\nTransfer Impact Assessment (TIA)\nFormal assessment before transferring personal information outside Quebec."];
        H3_DefaultPrivacy_Law25 [label="Control:\nDefault Highest Privacy Settings\nTechnologies must ship with the highest confidentiality enabled by default."];
        H3_BioDB_Reg_Law25 [label="Control:\nBiometric Database Registration\nNotify CAI >=60 days before creating a biometric database."];
        H3_BreachReport_PIPA [label="Control:\nMandatory Breach Reporting\nNotify Commissioner & individuals of any breach posing a Real Risk of Significant Harm (RROSH)."];
        H3_WrittenRelease_BIPA [label="Control:\nWritten Release and Consent\nObtain a legally binding written release before collecting biometric identifiers."];
        H3_BioRetention_BIPA [label="Control:\nBiometric Retention Schedule\nPublish a written policy for retention & permanent destruction of biometric data."];
        H3_CyberRiskAssessment_NYDFS [label="Control:\nCybersecurity Risk Assessment\nPeriodic, documented risk assessments that drive the cybersecurity program."];
        H3_CISO_Appointment_NYDFS [label="Control:\nCISO Appointment\nDesignate a qualified Chief Information Security Officer."];
        H3_AIBiasAudit_NYC [label="Control:\nIndependent AI Bias Audit\nSubject AEDTs to an independent bias audit prior to use and publish a summary."];
        H3_OptInHealth_MHMDA [label="Control:\nStrict Opt-In Consent for Health Data\nAffirmative opt-in required before collecting, sharing, or selling consumer health data (incl. geofencing near health facilities)."];
        H3_StudentRecordConsent_FERPA [label="Control:\nStudent Record Privacy\nObtain written permission from parent/eligible student before releasing PII from education records."];
        H3_NoDeceptive_FTC5 [label="Control:\nProhibition of Deceptive Practices\nAdhere to published privacy policies & security promises; failure = unfair/deceptive trade practice."];
        H3_TransferMechanism_GDPR [label="Control:\nTransfer Mechanisms & Schrems II\nImplement valid transfer mechanisms (SCCs, BCRs, etc.) + Transfer Impact Assessment to validate destination surveillance law."];
        H3_ConformityAssessment_AIAct [label="Control:\nConformity Assessments (High-Risk AI)\nProviders must undergo conformity assessment, implement risk-management, and ensure human oversight before market deployment."];
        H3_AITransparency_AIAct [label="Control:\nTransparency for AI Interactions\nDesign AI so users know they are interacting with AI; label deep-fakes/artificial content."];
        H3_UKRep_UKGDPR [label="Control:\nAppoint UK Representative\nControllers/processors outside the UK must appoint a domestic representative if they target/monitor UK residents."];
        H3_ISMS_ISO27001 [label="Control:\nInformation Security Management System (ISMS)\nEstablish, implement, maintain, and continually improve a documented ISMS covering people, processes, technology."];
    }

    // LAYER 3.5: PENALTIES
    subgraph cluster_penalty {
        label = "LAYER 3.5: Penalty & Infraction Mapping";
        Pen_OPC_Fed   [label="Penalty: OPC (Fed)\nUp to CAD 100k per violation"];
        Pen_OPC_ON    [label="Penalty: IPC ON\nPHIPA fines up to CAD 200k (individual) / 1M (org)"];
        Pen_OPC_QC    [label="Penalty: CAI QC\nAMPs up to CAD 10M or 2% turnover; penal up to 25M or 4%"];
        Pen_FTC       [label="Penalty: FTC\nCivil penalties per violation (adjusted annually)"];
        Pen_SEC       [label="Penalty: SEC\nCivil penalties + disgorgement"];
        Pen_EU_DPA    [label="Penalty: EU DPA\nUp to 4% global turnover\nor EUR 20M (whichever higher)"];
        Pen_HHS       [label="Penalty: HHS/HIPAA\nUp to USD 1.5M per violation category/year"];
    }

    // LAYER 4: OUTPUT ARTIFACTS
    subgraph cluster_output {
        label = "OUTPUT LAYER: Mandatory Artefacts & Actions";
        Out_RoPA       [label="[ARTIFACT]\nArticle 30 RoPA /\nData Flow Map"];
        Out_DPO        [label="[ACTION]\nRegister CPO/DPO with\nRegulatory Authority"];
        Out_QC_PIA     [label="[ARTIFACT]\nLaw 25 Baseline PIA"];
        Out_DPIA       [label="[ARTIFACT]\nArticle 35 DPIA"];
        Out_TIA_SCC    [label="[ARTIFACT]\nTIA + Executed SCCs"];
        Out_DSAR_Fill  [label="[ACTION]\nFulfill Request\n(30-45 Day SLA)"];
        Out_ADMT_OptOut[label="[ARTIFACT]\nAI Profiling Opt-Out UI\n& Logic Map"];
        Out_Breach_72h [label="[ACTION]\nRegulator Notification\n(72-Hour SLA)"];
        Out_Retention_Log[label="[ARTIFACT]\nCryptographic Proof\nof Data Destruction"];
        Out_PrivacyNotice   [label="[ARTIFACT]\nPublic Privacy Notice\n& Consent Records"];
        Out_TrainingRecord  [label="[ARTIFACT]\nPrivacy & Security Training Log"];
        Out_VendorAgreement [label="[ARTIFACT]\nVendor DPA / SCC Addendum"];
        Out_AccessReport    [label="[ARTIFACT]\nAccess-Control Review Report"];
        Out_EncryptCert     [label="[ARTIFACT]\nEncryption Key Management Certificate"];
        Out_IncidentReport  [label="[ACTION]\nFormal Incident Report\n& Post-Mortem"];
        Out_MonitoringLog   [label="[ARTIFACT]\nContinuous Monitoring Log\n(SIEM / Audit)"];
        Out_RetentionProof  [label="[ARTIFACT]\nRetention Schedule & Disposal Proof"];
        Out_AuditEvidence   [label="[ARTIFACT]\nRegulatory Audit Evidence Pack"];
        Out_CertReport      [label="[ARTIFACT]\nCertification Evidence Pack\n(SOC 1/2, CHI, HIPAA, EU-Eq)"];
        Out_FineNotice      [label="[ACTION]\nFine / Penalty Notice\nissued by regulator"];
        Out_CorrectiveOrder [label="[ACTION]\nCorrective Action Order\n(e.g., remediation plan)"];
        Out_PublicNaming    [label="[ACTION]\nPublic Naming / Press Release\nby regulator"];
        Out_CeaseDesist     [label="[ACTION]\nCease-and-Desist / Injunction"];
        Out_RemediationPlan [label="[ARTIFACT]\nRemediation & Improvement Plan\nrequired by regulator"];
        Out_TRA_Report          [label="[ARTIFACT]\nThreat and Risk Assessment Report"];
        Out_AgentAgreement      [label="[ARTIFACT]\nSigned Agent Agreement"];
        Out_FOI_Compliance      [label="[ARTIFACT]\nFreedom of Information Compliance Evidence"];
        Out_TIA_Report          [label="[ARTIFACT]\nTransfer Impact Assessment Report"];
        Out_DefaultPrivacy      [label="[ARTIFACT]\nDefault-Privacy Configuration Evidence"];
        Out_BioDB_Notice        [label="[ARTIFACT]\nCAI Biometric-Database Notification"];
        Out_BreachNotice_PIPA   [label="[ARTIFACT]\nBreach-Notice to Commissioner & Individuals"];
        Out_WrittenRelease      [label="[ARTIFACT]\nSigned Biometric Release Form"];
        Out_BioRetentionPolicy  [label="[ARTIFACT]\nPublished Biometric Retention Schedule"];
        Out_CyberRiskReport     [label="[ARTIFACT]\nDocumented Cybersecurity Risk Assessment"];
        Out_CISO_Appointment    [label="[ARTIFACT]\nAppointment Letter / CV of CISO"];
        Out_AIBiasAuditReport   [label="[ARTIFACT]\nIndependent AI Bias Audit Summary"];
        Out_OptInLog            [label="[ARTIFACT]\nOpt-In Consent Log (timestamped)"];
        Out_StudentRecordConsent[label="[ARTIFACT]\nWritten Consent for Student Record Release"];
        Out_ComplianceStatement [label="[ARTIFACT]\nPublic Privacy & Security Statement (matching practices)"];
        Out_TransferImpactAssessment[label="[ARTIFACT]\nTransfer Impact Assessment (TIA) + Executed SCCs"];
        Out_ConformityCert      [label="[ARTIFACT]\nEU AI-Act Conformity Certificate (high-risk AI)"];
        Out_AITransparencyNotice[label="[ARTIFACT]\nAI-Interaction Transparency Notice (UI label, deep-fake watermark)"];
        Out_UKRepAppointment    [label="[ARTIFACT]\nAppointment Letter of UK Representative"];
        Out_ISMSCert            [label="[ARTIFACT]\nISO/IEC 27001 Certificate"];
    }

    // INPUT -> STATUTES
    In_Loc_ON   -> H1_PHIPA;
    In_Loc_QC   -> H1_Law25;
    In_Loc_Fed  -> H1_PIPEDA;
    In_Loc_US_CA-> H1_CPRA;
    In_Loc_US_TX-> H1_CPRA;
    In_Loc_US_NY-> H1_CPRA;
    In_Loc_EU   -> H1_GDPR;
    In_Loc_UK   -> H1_UK_GDPR;
    In_Loc_AU   -> H1_APP;
    In_Loc_SG   -> H1_PDPA;
    In_Data_PHI -> H1_HIPAA;
    In_Data_PCI -> H1_PCI_DSS;
    In_Data_Fin -> H1_SOX;
    In_Data_IoT -> H1_NIST;
    In_Act_XBorder -> H1_GDPR;
    In_Act_XBorder -> H1_UK_GDPR;
    In_Act_XBorder -> H1_APP;
    In_Act_XBorder -> H1_PDPA;
    In_Act_AI      -> H1_GDPR;
    In_Act_AI      -> H1_UK_GDPR;
    In_Act_AI      -> H1_CPRA;
    In_Act_Mktg    -> H1_CPRA;
    In_Act_Mktg    -> H1_GDPR;
    In_Act_ThirdParty -> H1_GDPR;
    In_Act_ThirdParty -> H1_CPRA;
    In_Act_ThirdParty -> H1_PIPEDA;
    In_Evt_Breach  -> H1_GDPR;
    In_Evt_Breach  -> H1_HIPAA;
    In_Evt_Breach  -> H1_PIPEDA;
    In_Evt_DSAR    -> H1_GDPR;
    In_Evt_DSAR    -> H1_CPRA;
    In_Evt_DSAR    -> H1_PIPEDA;
    In_Evt_RegAudit-> H1_GDPR;
    In_Evt_RegAudit-> H1_SOX;
    In_Evt_RegAudit-> H1_PCI_DSS;
    In_Evt_PolicyChg-> H1_GDPR;
    In_Evt_PolicyChg-> H1_CPRA;
    In_Evt_PolicyChg-> H1_PIPEDA;
    In_Loc_ON   -> H1_FIPPA;
    In_Loc_Fed  -> H1_PIPA_AB;
    In_Loc_US_TX-> H1_BIPA;
    In_Loc_US_NY-> H1_NYDFS;
    In_Loc_US_NY-> H1_NYC_AIBias;
    In_Loc_US_TX-> H1_MHMDA;
    In_Loc_Fed  -> H1_FERPA;
    In_Loc_Fed  -> H1_FTCAct5;
    In_Loc_EU   -> H1_EU_AIAct;
    In_Loc_Fed  -> H1_ISO27001;

    // STATUTES -> TORTS
    H1_HIPAA   -> T_US_Intrusion;
    H1_HIPAA   -> T_US_PubDisc;
    H1_HIPAA   -> T_US_FalseLight;
    H1_HIPAA   -> T_US_Approp;
    H1_CPRA    -> T_US_Intrusion;
    H1_CPRA    -> T_US_PubDisc;
    H1_CPRA    -> T_US_FalseLight;
    H1_CPRA    -> T_US_Approp;
    H1_SOX     -> T_US_Intrusion;
    H1_PCI_DSS -> T_US_Intrusion;
    H1_BIPA    -> T_US_Intrusion;
    H1_BIPA    -> T_US_PubDisc;
    H1_BIPA    -> T_US_FalseLight;
    H1_BIPA    -> T_US_Approp;
    H1_PHIPA   -> T_CA_Intrusion;
    H1_PHIPA   -> T_CA_PubDisc;
    H1_PHIPA   -> T_CA_FalseLight;
    H1_PHIPA   -> T_CA_Approp;
    H1_Law25   -> T_CA_Intrusion;
    H1_Law25   -> T_CA_PubDisc;
    H1_Law25   -> T_CA_FalseLight;
    H1_Law25   -> T_CA_Approp;
    H1_PIPEDA  -> T_CA_Intrusion;
    H1_PIPEDA  -> T_CA_PubDisc;
    H1_PIPEDA  -> T_CA_FalseLight;
    H1_PIPEDA  -> T_CA_Approp;
    H1_FIPPA   -> T_CA_Intrusion;
    H1_FIPPA   -> T_CA_PubDisc;
    H1_FIPPA   -> T_CA_FalseLight;
    H1_FIPPA   -> T_CA_Approp;
    H1_PIPA_AB -> T_CA_Intrusion;
    H1_PIPA_AB -> T_CA_PubDisc;
    H1_PIPA_AB -> T_CA_FalseLight;
    H1_PIPA_AB -> T_CA_Approp;
    H1_GDPR    -> T_EU_Infringement;
    H1_GDPR    -> T_EU_BreachConf;
    H1_GDPR    -> T_EU_DataProtViol;
    H1_GDPR    -> T_EU_RTBF;
    H1_UK_GDPR -> T_EU_Infringement;
    H1_UK_GDPR -> T_EU_BreachConf;
    H1_UK_GDPR -> T_EU_DataProtViol;
    H1_UK_GDPR -> T_EU_RTBF;
    H1_APP     -> T_EU_Infringement;
    H1_PDPA    -> T_EU_Infringement;
    H1_EU_AIAct-> T_EU_Infringement;
    H1_NIST    -> T_US_Intrusion;
    H1_FTCAct5 -> T_US_Intrusion;
    H1_FERPA   -> T_US_Intrusion;
    H1_ISO27001-> T_US_Intrusion;

    // INPUT -> TORTS
    In_Data_PHI   -> T_US_Intrusion;
    In_Data_PHI   -> T_US_PubDisc;
    In_Data_Bio   -> T_US_Intrusion;
    In_Data_Bio   -> T_EU_Infringement;
    In_Data_PII   -> T_US_Intrusion;
    In_Data_PII   -> T_US_PubDisc;
    In_Data_PCI   -> T_US_Intrusion;
    In_Data_Fin   -> T_US_Intrusion;
    In_Data_IoT   -> T_EU_Infringement;
    In_Act_XBorder-> T_EU_Infringement;
    In_Act_XBorder-> T_US_Intrusion;
    In_Act_AI     -> T_US_FalseLight;
    In_Act_AI     -> T_EU_Infringement;
    In_Act_Mktg   -> T_US_PubDisc;
    In_Act_Mktg   -> T_EU_Infringement;
    In_Act_ThirdParty -> T_US_Intrusion;
    In_Act_ThirdParty -> T_EU_Infringement;
    In_Evt_Breach -> T_US_Intrusion;
    In_Evt_Breach -> T_EU_Infringement;
    In_Evt_DSAR   -> T_US_PubDisc;
    In_Evt_DSAR   -> T_EU_Infringement;
    In_Evt_RegAudit-> T_EU_Infringement;
    In_Evt_PolicyChg-> T_US_Intrusion;
    In_Evt_PolicyChg-> T_EU_Infringement;

    // TORTS -> GOVERNANCE (mitigation)
    T_US_Intrusion   -> H2_Gov_Policy;
    T_US_Intrusion   -> H2_Gov_Training;
    T_US_Intrusion   -> H2_Gov_Vendor;
    T_US_Intrusion   -> H2_Gov_Monitoring;
    T_US_Intrusion   -> H2_Gov_Incident;
    T_US_Intrusion   -> H2_Gov_Access;
    T_US_Intrusion   -> H2_Gov_Encrypt;
    T_US_Intrusion   -> H2_Gov_RetPol;
    T_US_PubDisc     -> H2_Gov_Policy;
    T_US_PubDisc     -> H2_Gov_Training;
    T_US_PubDisc     -> H2_Gov_Vendor;
    T_US_PubDisc     -> H2_Gov_Monitoring;
    T_US_PubDisc     -> H2_Gov_Incident;
    T_US_PubDisc     -> H2_Gov_Access;
    T_US_PubDisc     -> H2_Gov_Encrypt;
    T_US_PubDisc     -> H2_Gov_RetPol;
    T_US_FalseLight  -> H2_Gov_Policy;
    T_US_FalseLight  -> H2_Gov_Training;
    T_US_FalseLight  -> H2_Gov_Vendor;
    T_US_FalseLight  -> H2_Gov_Monitoring;
    T_US_FalseLight  -> H2_Gov_Incident;
    T_US_FalseLight  -> H2_Gov_Access;
    T_US_FalseLight  -> H2_Gov_Encrypt;
    T_US_FalseLight  -> H2_Gov_RetPol;
    T_US_Approp      -> H2_Gov_Policy;
    T_US_Approp      -> H2_Gov_Training;
    T_US_Approp      -> H2_Gov_Vendor;
    T_US_Approp      -> H2_Gov_Monitoring;
    T_US_Approp      -> H2_Gov_Incident;
    T_US_Approp      -> H2_Gov_Access;
    T_US_Approp      -> H2_Gov_Encrypt;
    T_US_Approp      -> H2_Gov_RetPol;
    T_CA_Intrusion   -> H2_Gov_Policy;
    T_CA_Intrusion   -> H2_Gov_Training;
    T_CA_Intrusion   -> H2_Gov_Vendor;
    T_CA_Intrusion   -> H2_Gov_Monitoring;
    T_CA_Intrusion   -> H2_Gov_Incident;
    T_CA_Intrusion   -> H2_Gov_Access;
    T_CA_Intrusion   -> H2_Gov_Encrypt;
    T_CA_Intrusion   -> H2_Gov_RetPol;
    T_CA_PubDisc     -> H2_Gov_Policy;
    T_CA_PubDisc     -> H2_Gov_Training;
    T_CA_PubDisc     -> H2_Gov_Vendor;
    T_CA_PubDisc     -> H2_Gov_Monitoring;
    T_CA_PubDisc     -> H2_Gov_Incident;
    T_CA_PubDisc     -> H2_Gov_Access;
    T_CA_PubDisc     -> H2_Gov_Encrypt;
    T_CA_PubDisc     -> H2_Gov_RetPol;
    T_CA_FalseLight  -> H2_Gov_Policy;
    T_CA_FalseLight  -> H2_Gov_Training;
    T_CA_FalseLight  -> H2_Gov_Vendor;
