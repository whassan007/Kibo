    {
      "@id": "kibo:H3_Encrypt",
      "@type": "kibo:ComplianceObligation",
      "label": "Encryption & Key Management"
    },
    {
      "@id": "kibo:H3_AccessCtrl",
      "@type": "kibo:ComplianceObligation",
      "label": "RBAC / MFA & Least Privilege"
    },
    {
      "@id": "kibo:H3_Monitoring",
      "@type": "kibo:ComplianceObligation",
      "label": "SIEM / Audit-Log Monitoring"
    },
    {
      "@id": "kibo:H3_IncidentPlan",
      "@type": "kibo:ComplianceObligation",
      "label": "Formal Incident Response Playbook"
    },
    {
      "@id": "kibo:H3_RetentionLog",
      "@type": "kibo:ComplianceObligation",
      "label": "Retention Schedule & Disposal Proof"
    },
    {
      "@id": "kibo:H3_TRA_PHIPA",
      "@type": "kibo:ComplianceObligation",
      "label": "Threat and Risk Assessment (TRA)",
      "kibo:description": "Custodians must conduct a TRA prior to introducing new EHR systems or major architectural changes."
    },
    {
      "@id": "kibo:H3_AgentAgreement_PHIPA",
      "@type": "kibo:ComplianceObligation",
      "label": "Agent Agreements",
      "kibo:description": "Written agreements with third-party agents restricting PHI use to authorized purposes."
    },
    {
      "@id": "kibo:H3_FOI_Compliance_FIPPA",
      "@type": "kibo:ComplianceObligation",
      "label": "Freedom of Information Compliance",
      "kibo:description": "Public institutions must respond to formal access to information requests within 30 days, applying specific statutory exemptions where necessary."
    },
    {
      "@id": "kibo:H3_TIA_Law25",
      "@type": "kibo:ComplianceObligation",
      "label": "Transfer Impact Assessment (TIA)",
      "kibo:description": "Formal assessment before transferring personal information outside Quebec."
    },
    {
      "@id": "kibo:H3_DefaultPrivacy_Law25",
      "@type": "kibo:ComplianceObligation",
      "label": "Default Highest Privacy Settings",
      "kibo:description": "Technologies must ship with the highest confidentiality enabled by default."
    },
    {
      "@id": "kibo:H3_BioDB_Reg_Law25",
      "@type": "kibo:ComplianceObligation",
      "label": "Biometric Database Registration",
      "kibo:description": "Notify CAI >=60 days before creating a biometric database."
    },
    {
      "@id": "kibo:H3_BreachReport_PIPA",
      "@type": "kibo:ComplianceObligation",
      "label": "Mandatory Breach Reporting",
      "kibo:description": "Notify Commissioner & individuals of any breach posing a Real Risk of Significant Harm (RROSH)."
    },
    {
      "@id": "kibo:H3_WrittenRelease_BIPA",
      "@type": "kibo:ComplianceObligation",
      "label": "Written Release and Consent",
      "kibo:description": "Obtain a legally binding written release before collecting biometric identifiers."
    },
    {
      "@id": "kibo:H3_BioRetention_BIPA",
      "@type": "kibo:ComplianceObligation",
      "label": "Biometric Retention Schedule",
      "kibo:description": "Publish a written policy for retention & permanent destruction of biometric data."
    },
    {
      "@id": "kibo:H3_CyberRiskAssessment_NYDFS",
      "@type": "kibo:ComplianceObligation",
      "label": "Cybersecurity Risk Assessment",
      "kibo:description": "Periodic, documented risk assessments that drive the cybersecurity program."
    },
    {
      "@id": "kibo:H3_CISO_Appointment_NYDFS",
      "@type": "kibo:ComplianceObligation",
      "label": "CISO Appointment",
      "kibo:description": "Designate a qualified Chief Information Security Officer."
    },
    {
      "@id": "kibo:H3_AIBiasAudit_NYC",
      "@type": "kibo:ComplianceObligation",
      "label": "Independent AI Bias Audit",
      "kibo:description": "Subject AEDTs to an independent bias audit prior to use and publish a summary."
    },
    {
      "@id": "kibo:H3_OptInHealth_MHMDA",
      "@type": "kibo:ComplianceObligation",
      "label": "Strict Opt-In Consent for Health Data",
      "kibo:description": "Affirmative opt-in required before collecting, sharing, or selling consumer health data (incl. geofencing near health facilities)."
    },
    {
      "@id": "kibo:H3_StudentRecordConsent_FERPA",
      "@type": "kibo:ComplianceObligation",
      "label": "Student Record Privacy",
      "kibo:description": "Obtain written permission from parent/eligible student before releasing PII from education records."
    },
    {
      "@id": "kibo:H3_NoDeceptive_FTC5",
      "@type": "kibo:ComplianceObligation",
      "label": "Prohibition of Deceptive Practices",
      "kibo:description": "Adhere to published privacy policies & security promises; failure = unfair/deceptive trade practice."
    },
    {
      "@id": "kibo:H3_TransferMechanism_GDPR",
      "@type": "kibo:ComplianceObligation",
      "label": "Transfer Mechanisms & Schrems II",
      "kibo:description": "Implement valid transfer mechanisms (SCCs, BCRs, etc.) + Transfer Impact Assessment to validate destination surveillance law."
    },
    {
      "@id": "kibo:H3_ConformityAssessment_AIAct",
      "@type": "kibo:ComplianceObligation",
      "label": "Conformity Assessments (High-Risk AI)",
      "kibo:description": "Providers must undergo conformity assessment, implement risk-management, and ensure human oversight before market deployment."
    },
    {
      "@id": "kibo:H3_AITransparency_AIAct",
      "@type": "kibo:ComplianceObligation",
      "label": "Transparency for AI Interactions",
      "kibo:description": "Design AI so users know they are interacting with AI; label deep-fakes/artificial content."
    },
    {
      "@id": "kibo:H3_UKRep_UKGDPR",
      "@type": "kibo:ComplianceObligation",
      "label": "Appoint UK Representative",
      "kibo:description": "Controllers/processors outside the UK must appoint a domestic representative if they target/monitor UK residents."
    },
    {
      "@id": "kibo:H3_ISMS_ISO27001",
      "@type": "kibo:ComplianceObligation",
      "label": "Information Security Management System (ISMS)",
      "kibo:description": "Establish, implement, maintain, and continually improve a documented ISMS covering people, processes, technology."
    },
    {
      "@id": "kibo:Pen_OPC_Fed",
      "@type": "kibo:PenaltyExposure",
      "label": "OPC (Fed)",
      "kibo:description": "Up to CAD 100k per violation"
    },
    {
      "@id": "kibo:Pen_OPC_ON",
      "@type": "kibo:PenaltyExposure",
      "label": "IPC ON",
      "kibo:description": "PHIPA fines up to CAD 200k (individual) / 1M (org)"
    },
    {
      "@id": "kibo:Pen_OPC_QC",
      "@type": "kibo:PenaltyExposure",
      "label": "CAI QC \u2014 AMPs up to CAD 10M or 2% of turnover; penal up to CAD 25M or 4% (Law 25)",
      "kibo:description": "AMPs up to CAD 10M or 2% turnover; penal up to 25M or 4%"
    },
    {
      "@id": "kibo:Pen_FTC",
